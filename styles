body{
    font-family: Arial;
    background:#f2f2f2;
    text-align:center;
    padding:30px;
}

.container{
    background:white;
    width:350px;
    margin:auto;
    padding:20px;
    border-radius:10px;
    box-shadow:0 0 10px gray;
}

input{
    width:90%;
    padding:10px;
    margin:10px;
}

button{
    background:blue;
    color:white;
    border:none;
    padding:10px 20px;
    cursor:pointer;
    border-radius:5px;
}

h2{
    color:#333;
}
